{
  "name": "scarneros/laravel-japan-postal-codes",
  "description": "Laravel package for looking up Japanese addresses by postal code. Supports kanji, kana and romaji, full-width character normalization, CSV imports from Japan Post, and an optional JSON API.",
  "license": "MIT",
  "keywords": [
    "laravel",
    "japan",
    "postal-code",
    "zip-code",
    "address",
    "japanese"
  ],
  "authors": [
    {
      "name": "Sergi Carneros",
      "email": "sergi@scarneros.com",
      "homepage": "https://sergicarneros.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0|^12.0|^13.0",
    "illuminate/database": "^11.0|^12.0|^13.0",
    "illuminate/http": "^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "orchestra/testbench": "^9.0|^10.0",
    "phpunit/phpunit": "^10.0|^11.0",
    "laravel/pint": "^1.29"
  },
  "autoload": {
    "psr-4": {
      "Scarneros\\JapanPostalCodes\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Scarneros\\JapanPostalCodes\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Scarneros\\JapanPostalCodes\\JapanPostalCodesServiceProvider"
      ],
      "aliases": {
        "PostalCode": "Scarneros\\JapanPostalCodes\\Facades\\PostalCode"
      }
    }
  },
  "scripts": {
    "test": "php vendor/bin/phpunit"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
